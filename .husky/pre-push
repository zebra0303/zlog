#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run coverage report before push
echo "🧪 코드 커버리지 측정 중..."
npm run test:coverage
if [ $? -ne 0 ]; then
  echo "❌ 커버리지 테스트 실패. 푸시를 중단합니다."
  exit 1
fi
echo "✅ 커버리지 측정 완료. (상세 리포트: server/coverage, client/coverage)"

echo "📊 측정 스크립트 실행: Lighthouse Core Web Vitals 측정 중..."
npm run vitals -w client

# vitals 스크립트가 성공적으로 실행되었는지 확인
if [ $? -eq 0 ]; then
  # 변경된 내용이 있는지 확인
  if ! git diff --quiet .ai-vitals.md; then
    # echo "📝 .ai-vitals.md 파일이 업데이트되었습니다."
    echo "📝 .ai-vitals.md 파일이 업데이트되었습니다. 추가 중..."
    # # prettier 적용
    npx prettier --write .ai-vitals.md
    
    git add .ai-vitals.md
    # git commit -m "chore: update Lighthouse Core Web Vitals (.ai-vitals.md)" --no-verify
    echo "✅ .ai-vitals.md 업데이트 및 추가 완료."
  else
    echo "⚡ 성능 지표에 변경 사항이 없습니다."
  fi
else
  echo "❌ Lighthouse 측정 실패. 푸시를 중단합니다."
  exit 1
fi